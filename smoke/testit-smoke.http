### JetBrains HTTP Client smoke for Test IT REST API
### Usage:
### 1. Select environment: `local`
### 2. Fill values in `smoke/http-client.env.json`
### 3. Run requests one by one
###
### This checks the same auth/header style and core endpoints that the MCP server uses.

@baseUrl = {{baseUrl}}
@token = {{token}}
@projectId = {{projectId}}
@testSuiteId = {{testSuiteId}}
@testPlanId = {{testPlanId}}
@testCaseId = {{testCaseId}}
@testRunId = {{testRunId}}
@testResultId = {{testResultId}}

### List projects
GET {{baseUrl}}/api/v2/projects?page=1&pageSize=10
Accept: application/json
Authorization: Bearer {{token}}

> {%
client.test("projects status is 200", function() {
  client.assert(response.status === 200, "Expected 200");
});
%}

### Get project
GET {{baseUrl}}/api/v2/projects/{{projectId}}
Accept: application/json
Authorization: Bearer {{token}}

> {%
client.test("project status is 200", function() {
  client.assert(response.status === 200, "Expected 200");
});
%}

### List test suites
GET {{baseUrl}}/api/v2/testPlans/{{testPlanId}}/testSuites
Accept: application/json
Authorization: Bearer {{token}}

> {%
client.test("test suites status is 200", function() {
  client.assert(response.status === 200, "Expected 200");
});
%}


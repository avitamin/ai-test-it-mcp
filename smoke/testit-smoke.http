### Search test cases
GET {{baseUrl}}/api/v2/projects/{{projectId}}/workItems?Skip=0&Take=10
Accept: application/json
Authorization: Bearer {{token}}

> {%
client.test("test cases status is 200", function() {
  client.assert(response.status === 200, "Expected 200");
});
%}

### Get test case
GET {{baseUrl}}/api/v2/workItems/{{testCaseId}}
Accept: application/json
Authorization: Bearer {{token}}

> {%
client.test("test case status is 200", function() {
  client.assert(response.status === 200, "Expected 200");
});
%}

### List test runs
GET {{baseUrl}}/api/v2/projects/{{projectId}}/testRuns?notStarted=true&inProgress=true&stopped=true&completed=true&Skip=0&Take=10
Accept: application/json
Authorization: Bearer {{token}}

> {%
client.test("test runs status is 200", function() {
  client.assert(response.status === 200, "Expected 200");
});
%}

### Get test run
GET {{baseUrl}}/api/v2/testRuns/{{testRunId}}
Accept: application/json
Authorization: Bearer {{token}}

> {%
client.test("test run status is 200", function() {
  client.assert(response.status === 200, "Expected 200");
});
%}

### List test results
POST {{baseUrl}}/api/v2/testResults/search?Skip=0&Take=10
Accept: application/json
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "projectIds": ["{{projectId}}"]
}

> {%
client.test("test results status is 200", function() {
  client.assert(response.status === 200, "Expected 200");
});
%}

### Get test result
GET {{baseUrl}}/api/v2/testResults/{{testResultId}}
Accept: application/json
Authorization: Bearer {{token}}

> {%
client.test("test result status is 200", function() {
  client.assert(response.status === 200, "Expected 200");
});
%}

### Auth negative check
GET {{baseUrl}}/api/v2/projects?page=1&pageSize=1
Accept: application/json
Authorization: Bearer invalid-token

> {%
client.test("invalid token is rejected", function() {
  client.assert(response.status === 401 || response.status === 403, "Expected 401 or 403");
});
%}
